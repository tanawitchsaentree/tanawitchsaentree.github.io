{
    "version": "1.1.0",
    "lastUpdated": "2026-03-20",
    "tokens": {
        "spacing": {
            "micro": "var(--space-1)",
            "xs": "var(--space-2)",
            "sm": "var(--space-3)",
            "base": "var(--space-4)",
            "md": "var(--space-5)",
            "lg": "var(--space-6)",
            "xl": "var(--space-8)",
            "2xl": "var(--space-10)",
            "3xl": "var(--space-12)",
            "4xl": "var(--space-16)"
        },
        "typography": {
            "metadata": "var(--text-sm)",
            "body": "var(--text-base)",
            "heading": "var(--text-lg)",
            "fontMono": "var(--font-mono)",
            "fontSans": "var(--font-sans)"
        },
        "colors": {
            "surface": "var(--background)",
            "text": "var(--foreground)",
            "brand": "var(--primary)",
            "brandText": "var(--primary-foreground)",
            "secondary": "var(--secondary)",
            "secondaryText": "var(--secondary-foreground)",
            "muted": "var(--muted)",
            "mutedText": "var(--muted-foreground)",
            "border": "var(--border)",
            "destructive": "var(--destructive)"
        },
        "other": {
            "radius": "var(--radius)"
        }
    },
    "components": {
        "RetroButton": {
            "type": "button",
            "path": "src/components/ui/RetroButton.tsx",
            "description": "Hard-edge button with shadow for retro aesthetic",
            "props": {
                "variant": {
                    "type": "string",
                    "options": [
                        "primary",
                        "secondary"
                    ],
                    "default": "primary"
                },
                "disabled": {
                    "type": "boolean",
                    "default": false
                }
            },
            "tokens": {
                "padding": "var(--space-2) var(--space-3)",
                "fontSize": "var(--text-sm)",
                "fontFamily": "var(--font-mono)",
                "border": "2px solid var(--foreground)",
                "borderRadius": "0",
                "background": "transparent",
                "color": "var(--foreground)",
                "shadow": "4px 4px 0px 0px var(--foreground)"
            },
            "states": {
                "hover": {
                    "transform": "translate(-1px, -1px)",
                    "shadow": "5px 5px 0px 0px var(--foreground)"
                },
                "active": {
                    "transform": "translate(2px, 2px)",
                    "shadow": "1px 1px 0px 0px var(--foreground)"
                },
                "disabled": {
                    "opacity": "0.5",
                    "cursor": "not-allowed"
                }
            },
            "spacing": {
                "group": {
                    "gap": "var(--space-8)",
                    "reason": "Accounts for 4px shadow offset + visual breathing room"
                }
            },
            "usage": {
                "pattern": "docs/design-system/patterns/buttons.md",
                "example": "import { RetroButton } from '@/components/ui/RetroButton';\n\n<RetroButton onClick={handleClick}>\n  Click Me\n</RetroButton>"
            }
        },
        "SmartTooltip": {
            "type": "overlay",
            "path": "src/components/ui/SmartTooltip.tsx",
            "status": "implemented",
            "description": "Cursor-following tooltip that auto-flips to stay within viewport. Wraps any child element — no ref required.",
            "when_to_use": [
                "Icon buttons with no visible label (social icons, theme toggle, copy button)",
                "Interactive elements that need contextual hint without cluttering the layout",
                "Any hover interaction in the portfolio where extra context adds value without needing a full popover",
                "When the element is small and the label/action isn't self-evident"
            ],
            "do_not_use_when": [
                "The element already has clear visible text",
                "The hint requires more than 2 short lines — use a popover instead",
                "On mobile (tooltip is desktop-only interaction)"
            ],
            "props": {
                "content": {
                    "type": "React.ReactNode",
                    "required": true,
                    "description": "Tooltip content — string or JSX (e.g. two-line label+tagline)"
                },
                "children": {
                    "type": "React.ReactElement",
                    "required": true,
                    "description": "Single child element to attach hover behavior to"
                },
                "delay": {
                    "type": "number",
                    "default": 350,
                    "description": "ms before tooltip appears. 350ms feels intentional. Use 200ms for utility actions, 500ms for ambient context."
                }
            },
            "behavior": {
                "positioning": "Follows mouse cursor in real-time. Initial position fires at latest cursor position after delay (not entry point).",
                "flip": "Auto-selects one of 4 placements (top-right, top-left, bottom-right, bottom-left) based on viewport edge proximity",
                "animation": "Scale from cursor-nearest corner + fade. transformOrigin matches placement.",
                "portal": "Renders in document.body — never clipped by overflow:hidden containers"
            },
            "tokens": {
                "background": "var(--foreground)",
                "color": "var(--background)",
                "borderRadius": "var(--radius)",
                "padding": "10px 16px",
                "fontSize": "var(--text-base)",
                "fontFamily": "var(--font-sans)"
            },
            "usage": {
                "example": "import { SmartTooltip } from '@/components/ui/SmartTooltip';\n\n<SmartTooltip content=\"Copy email\">\n  <button onClick={handleCopy}>\n    <Copy size={14} />\n  </button>\n</SmartTooltip>",
                "two_line_example": "<SmartTooltip content={\n  <div>\n    <div style={{ fontWeight: 700 }}>LinkedIn</div>\n    <div style={{ opacity: 0.6, fontSize: '11px' }}>let's connect</div>\n  </div>\n}>\n  <a href={url}>...</a>\n</SmartTooltip>",
                "current_usages": [
                    "src/pages/index.tsx → SocialIcon (LinkedIn, Medium, Behance)",
                    "src/pages/index.tsx → copy email button",
                    "src/App.tsx → DarkModeToggle"
                ]
            }
        },
        "PinnedCard": {
            "type": "content-card",
            "path": "src/components/ui/PinnedCard.tsx",
            "status": "implemented",
            "description": "Physical 'memo on a board' card with pushpin, slight rotation, and lined-paper texture. Pairs with PinnedCardsSection in ProjectModal for zigzag layout.",
            "when_to_use": [
                "Design decisions with numbered rationale (3–5 items)",
                "Research insights or interview findings",
                "Key learnings / retrospective takeaways",
                "User quotes pinned as memos",
                "Feature spec cards, HMW questions, design principles"
            ],
            "do_not_use_when": [
                "More than 6 items — loses the 'intentional memo' weight",
                "Content without a title — pins need a headline anchor",
                "Tabular or comparison data — use a table or before_after instead"
            ],
            "props": {
                "number": { "type": "string", "required": true, "description": "Ordinal label e.g. '01'" },
                "title": { "type": "string", "required": true },
                "description": { "type": "string", "required": true },
                "index": { "type": "number", "required": true, "description": "0-based — drives rotation, tint, pin color, and left/right zigzag alignment" },
                "visible": { "type": "boolean", "default": true, "description": "Entrance animation trigger (pass from IntersectionObserver)" },
                "delay": { "type": "number", "default": 0, "description": "seconds — stagger delay for entrance animation" }
            },
            "behavior": {
                "layout": "Zigzag: even index = left-aligned, odd = right-aligned. Width: 62% of container.",
                "rotation": "Alternating subtle angles (ROTATIONS array) — max ±2.6 degrees",
                "colors": "4-slot pin colors and card tints cycle by index. All tints are low-opacity rgba — theme-safe.",
                "texture": "Lined paper via repeating-linear-gradient on an overlay div",
                "entrance": "scale(0.88) + translateY(24px) → identity on visible=true, stagger by delay prop"
            },
            "tokens": {
                "background": "var(--muted) + radial tint overlay",
                "border": "var(--border)",
                "borderRadius": "12px",
                "titleSize": "var(--modal-body)",
                "descriptionSize": "var(--modal-body)",
                "numberFont": "var(--font-mono)"
            },
            "usage": {
                "example": "import { PinnedCard } from '@/components/ui/PinnedCard';\n\n<div style={{ display: 'flex', flexDirection: 'column', gap: 40 }}>\n  {items.map((item, i) => (\n    <PinnedCard key={i} number={item.number} title={item.title}\n      description={item.description} index={i}\n      visible={visible} delay={i * 0.12} />\n  ))}\n</div>",
                "current_usages": [
                    "src/components/ProjectModal.tsx → PinnedCardsSection → allianz-doc-classification decisions"
                ]
            }
        },
        "SuggestionGroup": {
            "type": "container",
            "cssClass": "suggestion-buttons",
            "path": "src/index.css",
            "description": "Container for suggestion button groups",
            "tokens": {
                "display": "flex",
                "flexWrap": "wrap",
                "gap": "var(--space-8)",
                "marginTop": "var(--space-3)"
            },
            "children": [
                "RetroButton"
            ],
            "usage": {
                "pattern": "docs/design-system/patterns/chatbox.md",
                "example": "<div className=\"suggestion-buttons\">\n  <RetroButton>Option 1</RetroButton>\n  <RetroButton>Option 2</RetroButton>\n</div>"
            }
        }
    },
    "sections": {
        "ChatBox": {
            "pattern": "docs/design-system/patterns/chatbox.md",
            "description": "Chat interface section",
            "container": {
                "cssClass": "chatbox-container",
                "maxWidth": "600px",
                "margin": "0",
                "alignment": "left"
            },
            "components": [
                "RetroButton",
                "SuggestionGroup"
            ],
            "spacing": {
                "containerPadding": "var(--space-8)",
                "messageGap": "var(--space-3)",
                "suggestionMarginTop": "var(--space-3)"
            }
        },
        "Layout": {
            "pattern": "docs/design-system/patterns/layout.md",
            "description": "Main grid layout (Profile | Chat/Work)",
            "structure": {
                "mobile": "single panel, tab-switched via bottom nav (profile / work / chat)",
                "tablet": "1fr 1fr grid (768–1023px)",
                "desktop": "2fr 3fr grid (≥1024px)"
            },
            "containers": {
                "profileSection": {
                    "alignment": "center",
                    "maxWidth": "none",
                    "fills": "50% of grid"
                },
                "chatSection": {
                    "alignment": "flex-start",
                    "paddingLeft": "var(--space-8)",
                    "contains": "chatbox-container"
                }
            }
        }
    },
    "patterns": {
        "buttons": "docs/design-system/patterns/buttons.md",
        "chatbox": "docs/design-system/patterns/chatbox.md",
        "layout": "docs/design-system/patterns/layout.md",
        "typography": "docs/design-system/patterns/typography.md",
        "composition": "docs/design-system/patterns/composition.md"
    },
    "componentTypes": {
        "simple": "Single-purpose component (e.g., Button)",
        "compound": "Component with sub-components (e.g., Modal.Header)",
        "contextual": "Adapts based on user context or props"
    },
    "compoundComponents": {
        "Modal": {
            "type": "compound",
            "path": "src/components/ui/Modal/index.tsx",
            "status": "planned",
            "pattern": "docs/design-system/patterns/composition.md",
            "description": "Flexible modal with composable sub-components for context-aware layouts",
            "structure": {
                "required": [
                    "Modal.Body"
                ],
                "optional": [
                    "Modal.Header",
                    "Modal.Footer"
                ]
            },
            "subComponents": {
                "Modal.Header": {
                    "description": "Modal title section",
                    "tokens": {
                        "padding": "var(--space-4)",
                        "borderBottom": "1px solid var(--border)",
                        "fontSize": "var(--text-lg)",
                        "fontWeight": "bold"
                    }
                },
                "Modal.Body": {
                    "description": "Main modal content",
                    "tokens": {
                        "padding": "var(--space-4)",
                        "minHeight": "100px"
                    }
                },
                "Modal.Footer": {
                    "description": "Action buttons container",
                    "tokens": {
                        "padding": "var(--space-4)",
                        "gap": "var(--space-3)",
                        "display": "flex",
                        "justifyContent": "flex-end",
                        "borderTop": "1px solid var(--border)"
                    }
                }
            },
            "contextVariants": {
                "simple": {
                    "description": "User 1: Image + 1 button",
                    "uses": [
                        "Modal.Body"
                    ],
                    "example": "<Modal>\n  <Modal.Body>\n    <Image />\n    <RetroButton>OK</RetroButton>\n  </Modal.Body>\n</Modal>"
                },
                "standard": {
                    "description": "User 2: Title + content + 2 buttons",
                    "uses": [
                        "Modal.Header",
                        "Modal.Body",
                        "Modal.Footer"
                    ],
                    "example": "<Modal>\n  <Modal.Header>Title</Modal.Header>\n  <Modal.Body>Content</Modal.Body>\n  <Modal.Footer>\n    <RetroButton>Cancel</RetroButton>\n    <RetroButton>OK</RetroButton>\n  </Modal.Footer>\n</Modal>"
                }
            },
            "usage": {
                "pattern": "docs/design-system/patterns/composition.md",
                "flexibility": "infinite",
                "note": "One component handles all modal variations through composition"
            }
        }
    },
    "themes": {
        "available": [
            "light",
            "dark",
            "twilight"
        ],
        "default": "light",
        "selector": {
            "light": ":root",
            "dark": ".dark",
            "twilight": ".twilight"
        },
        "testing": {
            "required": true,
            "message": "All CSS changes must be tested in all 3 themes"
        }
    }
}